# WebAuthn 設定（必須）
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:8080,http://localhost:3000

# Gemini AI（任意、未設定時は AI 生成ボタン非表示）
# GEMINI_API_KEY=your-api-key
# GEMINI_MODEL=gemini-2.5-flash

# Firebase サービスアカウント（任意、デフォルト: firebase-service-account.json）
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Passkey DB（任意、デフォルト: data/passkey.db）
# PASSKEY_DB_PATH=data/passkey.db

# Swagger UI（任意、true で /swagger を有効化。本番では設定しない）
SWAGGER_ENABLED=true
